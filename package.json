{
  "name": "foolish-you",
  "version": "1.2.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:rtl": "jest --selectProjects rtl --testTimeout=20000",
    "test:unit": "jest --selectProjects unit",
    "test:migration": "jest --selectProjects unit --testPathPattern=__tests__/lib/storage/migration",
    "lint": "expo lint",
    "lockfile:sync": "npx npm@10.9.2 install",
    "lockfile:verify-eas": "npx npm@10.9.2 ci",
    "typecheck": "tsc --noEmit",
    "hooks:install": "git config core.hooksPath .githooks",
    "frontend:review-gate": "bash scripts/frontend-review-gate.sh working",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:production": "eas build --platform all --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.8.0",
    "@types/react": "~19.1.0",
    "eslint-config-expo": "~10.0.0",
    "expo-atlas": "^0.4.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
